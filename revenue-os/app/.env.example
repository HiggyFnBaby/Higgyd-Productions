# Copy this file to .env and fill in real values. Nothing here is optional
# for the app to actually run end to end — but you can get it compiling and
# the UI loading before every value is real.

# --- Database ---
# A real Postgres connection string. Free options: Supabase, Neon, Railway.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://user:password@localhost:5432/revenue_os"

# --- Auth ---
# NEXTAUTH_SECRET: any long random string, used to encrypt session tokens.
# Generate one with: openssl rand -base64 32
NEXTAUTH_SECRET=""
# The URL this app is running at. http://localhost:3000 for local dev.
NEXTAUTH_URL="http://localhost:3000"

# --- Claude API (powers the "Run agent" button on a lead) ---
# Get a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=""
# Optional override; defaults to claude-sonnet-4-5 if unset.
ANTHROPIC_MODEL="claude-sonnet-4-5"

# --- Billing ---
# Which payment processor to use. Only "stripe" is implemented so far —
# see src/lib/billing/index.ts for how to add Paddle/LemonSqueezy later.
BILLING_PROVIDER="stripe"
# From https://dashboard.stripe.com/apikeys (use a test key while building)
STRIPE_SECRET_KEY=""
# The recurring Price you create in the Stripe Dashboard for this product's
# subscription (Product catalog > your product > pricing).
STRIPE_PRICE_ID=""
# From the Stripe CLI (`stripe listen --forward-to localhost:3000/api/billing/webhook`)
# or from the webhook endpoint you configure in the Stripe Dashboard.
STRIPE_WEBHOOK_SECRET=""
